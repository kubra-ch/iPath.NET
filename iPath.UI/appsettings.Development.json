{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
        "MinimumLevel": "Information",
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": "C:\\Daten\\tmp\\ipath.net\\log\\iPath-.txt",
                    "rollingInterval": "Day"
                }
            }
        ],
        "Enrich": [ "FromLogContext", "WithMachineName" ],
        "Properties": {
            "ApplicationName": "iPath.NET"
        }
    },
    "ConnectionStrings": {
        "iPathNetConnectionString_dev": "Server=basyssrvdev1;Database=iPathNet;Integrated Security=true;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true",
        "iPathNetConnectionString": "Server=localhost\\SQLEXPRESS;Database=iPathNet_Data;Integrated Security=true;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
    },
    "iPathConfig": {
        "BaseUrl": "https://localhost:7199/",
        "DataPath": "C:\\Daten\\tmp\\ipath.net\\data",
        "DataPathReadonly": "\\\\nas2\\BACKUP\\www\\ipath\\data",
        "ThumbSize": 90,
        "AutoMigrateDatabase": true
    }
