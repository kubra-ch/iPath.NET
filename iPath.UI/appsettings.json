{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.File" ],
        "MinimumLevel": "Information",
        "WriteTo": [
            {
                "Name": "Console"
            },
            {
                "Name": "File",
                "Args": {
                    "path": ".\\log\\iPath-.txt",
                    "rollingInterval": "Day"
                }
            }
        ],
        "Enrich": [ "FromLogContext", "WithMachineName" ],
        "Properties": {
            "ApplicationName": "iPath.NET"
        }
    },
    "Provider": "MSSQL", // MSSQL, Postgres, SQLite
    "ConnectionStrings": {
        "iPathNetConnectionString_MSSQL": "Server=dbserver;Database=iPathNet;Integrated Security=true;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true",
        "iPathNetConnectionString_Postgres": "Server=basyssrvdb1;Database=iPathNet;Integrated Security=true;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true",
        "iPathNetConnectionString_SQLite": "Data Source=ipath.db"
    },
    "iPathConfig": {
        "BaseUrl": ".\\data",
        "ThumbSize": 90,
        "AutoMigrateDatabase": false
    },
    "AllowedHosts": "*"
}
